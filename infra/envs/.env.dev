# Development Environment Variables

# Server Configuration
PORT=3000

# Database Configuration
DB_PROVIDER=postgres
MONGO_URI=mongodb://root:example@mongo:27017/auth_dev?authSource=admin
POSTGRES_URI=postgresql://user:password@postgres:5432/auth_dev

# JWT Configuration
JWT_SECRET=dev_jwt_access_secret_key_at_least_32_chars_long
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_at_least_32_chars_long

# Encryption Configuration
ENCRYPTION_KEY_BASE64=Q+7WLxKQxqM9rGP2Oh+3pADS7ZVa77g/g1FGG//O8VM=

# Node Environment
NODE_ENV=development
