# Development Environment Variables

# Server Configuration
PORT=3000

# Database Configuration (postgres|mongo)
DB_PROVIDER=postgres
MONGO_URI=mongodb://root:example@mongo:27017/auth_dev?authSource=admin
POSTGRES_URI=postgresql://user:password@postgres:5432/auth_dev

# JWT Configuration (minimum 32 characters each)
JWT_SECRET=<replace-with-a-secret-at-least-32-chars-long>
JWT_REFRESH_SECRET=<replace-with-a-different-secret-at-least-32-chars-long>

# Encryption Configuration (must decode to exactly 32 bytes: openssl rand -base64 32)
ENCRYPTION_KEY_BASE64=<replace-with-openssl-rand-base64-32-output>

# Node Environment
NODE_ENV=development
